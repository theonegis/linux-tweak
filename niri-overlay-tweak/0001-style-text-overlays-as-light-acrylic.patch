+    rounded_rectangle(cr, 0., 0., width, height, radius);
+    let background = cairo::LinearGradient::new(0., 0., 0., height);
+    background.add_color_stop_rgba(0., 0.965, 0.970, 0.980, 0.90);
+    background.add_color_stop_rgba(1., 0.845, 0.855, 0.875, 0.86);
+    cr.set_source(&background)?;
+    cr.fill()?;
+
+    cr.save()?;
+    rounded_rectangle(cr, 0., 0., width, height, radius);
+    cr.clip();
+    let step = (6. * scale).round().max(5.) as usize;
+    cr.set_source_rgba(1., 1., 1., 0.035);
+    for y in (0..height as usize).step_by(step) {
