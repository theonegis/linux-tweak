class FileDialogManager(dbus.service.Object):
    def __init__(self, bus):
        super().__init__(bus, MANAGER_PATH)
        self.bus = bus
        self.counter = 0
        self.dialogs_by_path = {}
        log("manager started")

    @dbus.service.method(INTROSPECT_IFACE, out_signature="s")
    def Introspect(self):
        log("manager Introspect")
        return MANAGER_XML

    @dbus.service.method(MANAGER_IFACE, in_signature="s", out_signature="o")
    def createDialog(self, key):
        self.counter += 1
        path = f"/com/deepin/filemanager/filedialog/{self.counter}"
        self.dialogs_by_path[path] = FileDialog(self.bus, path, self, key)
        log(f"createDialog key={key} -> {path}")
        return dbus.ObjectPath(path)

    def destroy_path(self, path):
        dialog = self.dialogs_by_path.pop(str(path), None)
        if dialog:
            dialog.remove_from_connection()
            log(f"destroyed {path}")

    @dbus.service.method(MANAGER_IFACE, in_signature="o")
    def destroyDialog(self, path):
        log(f"destroyDialog {path}")
        self.destroy_path(path)

    @dbus.service.method(MANAGER_IFACE, out_signature="ao")
    def dialogs(self):
        log("dialogs")
        return dbus.Array([dbus.ObjectPath(path) for path in self.dialogs_by_path], signature="o")

    @dbus.service.method(MANAGER_IFACE, out_signature="s")
    def errorString(self):
        log("errorString")
        return ""

    @dbus.service.method(MANAGER_IFACE, out_signature="b")
    def isUseFileChooserDialog(self):
        log("isUseFileChooserDialog -> true")
        return True

    @dbus.service.method(MANAGER_IFACE, in_signature="ss", out_signature="b")
    def canUseFileChooserDialog(self, group, executableFileName):
        log(f"canUseFileChooserDialog group={group} executable={executableFileName} -> true")
        return True

    @dbus.service.method(MANAGER_IFACE, in_signature="s", out_signature="as")
    def globPatternsForMime(self, mime):
        log(f"globPatternsForMime {mime}")
        return dbus.Array([], signature="s")

    @dbus.service.method(MANAGER_IFACE, out_signature="as")
    def monitorFiles(self):
        log("monitorFiles")
        return dbus.Array([], signature="s")

    @dbus.service.method(MANAGER_IFACE, in_signature="sas")
    def showBluetoothTransDialog(self, ident, uris):
        log(f"showBluetoothTransDialog id={ident} uris={list(uris)}")


def check_running():
    DBusGMainLoop(set_as_default=True)
    bus = dbus.SessionBus()
    try:
        bus.get_name_owner(BUS_NAME)
        return 0
    except dbus.DBusException:
        return 1


def main():
    if "--check" in sys.argv:
        return check_running()

    DBusGMainLoop(set_as_default=True)
    bus = dbus.SessionBus()
    name = dbus.service.BusName(BUS_NAME, bus, allow_replacement=False, replace_existing=False, do_not_queue=True)
    FileDialogManager(bus)
    log(f"owning {BUS_NAME}: {name.get_name()}")
    GLib.MainLoop().run()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
