def log(message):
    stamp = time.strftime("%Y-%m-%d %H:%M:%S")
    with open(LOG_PATH, "a", encoding="utf-8") as file:
        file.write(f"[{stamp}] {message}\n")


def file_uri_to_path(uri):
    parsed = urlparse(str(uri))
    if parsed.scheme == "file":
        return unquote(parsed.path)
    return str(uri)


class FileDialog(dbus.service.Object):
    def __init__(self, bus, path, manager, key):
        super().__init__(bus, path)
        self.bus = bus
        self.path = path
        self.manager = manager
        self.key = key
        self.title = "Open"
        self.directory = str(Path.home())
        self.directory_url = ""
        self.name_filters = dbus.Array([], signature="s")
        self.selected_filter = ""
        self.selected_filter_index = 0
        self.selected_files_value = dbus.Array([], signature="s")
        self.selected_urls_value = dbus.Array([], signature="s")
        self.current_input_name = ""
        self.file_mode = 1
        self.accept_mode = 0
        self.options_value = 0
        self.hide_on_accept = True
        self.window_flags = dbus.UInt32(0)
        self.heartbeat_interval = 0
        self.window_active = False
        self.portal_request = None
        log(f"dialog created path={path} key={key}")

    def _property_map(self):
        return {
            "directory": dbus.String(self.directory, variant_level=1),
            "directoryUrl": dbus.String(self.directory_url, variant_level=1),
            "nameFilters": dbus.Array(self.name_filters, signature="s", variant_level=1),
            "filter": dbus.Int32(self.selected_filter_index, variant_level=1),
            "viewMode": dbus.Int32(0, variant_level=1),
            "acceptMode": dbus.Int32(self.accept_mode, variant_level=1),
            "windowActive": dbus.Boolean(self.window_active, variant_level=1),
            "heartbeatInterval": dbus.Int32(self.heartbeat_interval, variant_level=1),
            "windowFlags": dbus.UInt32(self.window_flags, variant_level=1),
            "hideOnAccept": dbus.Boolean(self.hide_on_accept, variant_level=1),
        }

    def _set_directory_hint(self, value):
        path = file_uri_to_path(value)
        if os.path.isdir(path):
            self.directory = path
            log(f"{self.path} directory hint -> {self.directory}")
            return

        directory = os.path.dirname(path.rstrip(os.sep))
        if directory and os.path.isdir(directory):
            self.directory = directory
            log(f"{self.path} directory hint parent -> {self.directory}")

    def _remember_default_name_from_path(self, value):
        path = file_uri_to_path(value)
        self._set_directory_hint(path)

        name = os.path.basename(path.rstrip(os.sep))
        if name:
            self.current_input_name = name
            log(f"{self.path} default filename -> {self.current_input_name}")

    @dbus.service.method(INTROSPECT_IFACE, out_signature="s")
    def Introspect(self):
        log(f"{self.path} Introspect")
        return DIALOG_XML

    @dbus.service.method(PROPERTIES_IFACE, in_signature="ss", out_signature="v")
    def Get(self, interface, prop):
        log(f"{self.path} Properties.Get {interface}.{prop}")
        return self._property_map().get(prop, dbus.String("", variant_level=1))

    @dbus.service.method(PROPERTIES_IFACE, in_signature="ssv")
    def Set(self, interface, prop, value):
        log(f"{self.path} Properties.Set {interface}.{prop}={value!r}")
        if prop == "directory":
            self._set_directory_hint(value)
        elif prop == "directoryUrl":
            self.directory_url = str(value)
            self._set_directory_hint(value)
        elif prop == "nameFilters":
            self.name_filters = dbus.Array(value, signature="s")
        elif prop == "filter":
            self.selected_filter_index = int(value)
        elif prop == "acceptMode":
            self.accept_mode = int(value)
        elif prop == "heartbeatInterval":
            self.heartbeat_interval = int(value)
        elif prop == "windowFlags":
            self.window_flags = dbus.UInt32(value)
        elif prop == "hideOnAccept":
            self.hide_on_accept = bool(value)

    @dbus.service.method(PROPERTIES_IFACE, in_signature="s", out_signature="a{sv}")
    def GetAll(self, interface):
        log(f"{self.path} Properties.GetAll {interface}")
        return self._property_map()

    @dbus.service.method(DIALOG_IFACE, in_signature="s")
    def selectFile(self, filename):
        log(f"{self.path} selectFile {filename}")
        self.selected_files_value = dbus.Array([filename], signature="s")
        self._remember_default_name_from_path(filename)

    @dbus.service.method(DIALOG_IFACE, out_signature="as")
    def selectedFiles(self):
