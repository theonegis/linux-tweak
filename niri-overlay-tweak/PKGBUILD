# Maintainer: Tanzhenyu <tanzhenyu@localhost>

pkgname=niri-acrylic
pkgver=26.04
pkgrel=1
pkgdesc='Niri with light-grey acrylic native text information overlays'
arch=('x86_64')
url='https://github.com/YaLTeR/niri'
license=('GPL-3.0-or-later')
# See PKGBUILD.local: PipeWire's libspa-sys C wrappers must not use makepkg's
# global GCC LTO when the Rust binary is linked with clang/lld.
options=('!lto')
depends=(
  'cairo'
  'glib2'
  'glibc'
  'inter-font'
  'libdisplay-info'
  'libgcc'
  'libinput'
  'libpipewire'
  'libxkbcommon'
  'mesa'
  'pango'
  'pixman'
  'seatd'
  'systemd-libs'
  'xdg-desktop-portal-impl'
)
makedepends=(
  'clang'
  'rust'
)
optdepends=(
  'alacritty: suggested GPU-accelerated terminal emulator'
  'bash: niri-session login-shell support'
  'fuzzel: suggested Wayland application launcher'
  'mako: suggested Wayland notification daemon'
  'org.freedesktop.secrets: secret-service support for applications'
  'swaybg: suggested Wayland wallpaper utility'
  'swaylock: suggested Wayland screen locker'
  'waybar: suggested status bar'
  'xwayland-satellite: X11 application support through XWayland'
  'xdg-desktop-portal-gtk: suggested desktop portal'
  'xdg-desktop-portal-gnome: desktop portal required for screencasting'
)
provides=(
  "niri=${pkgver}"
  'wayland-compositor'
)
conflicts=('niri')
source=(
  "niri-${pkgver}.tar.gz::${url}/archive/refs/tags/v${pkgver}.tar.gz"
  '0001-style-text-overlays-as-light-acrylic.patch'
)
b2sums=(
  '65fc4df85ab40c1a7a82900a9812c542a8a00467a0f1742f2dede50c0e323bd8957149e91b181a6c71ad077735f6a4db53451bbad0deb768f7d4840ebe798a20'
  '595b6cdca0f4513ac2bff8b973dfe81902f68a5165595ce23e01adecd8699bd91033935154048bccb60b91abc7d1e3a4030505110fdb13d2e2b8749acfd91098'
)

prepare() {
  cd "niri-${pkgver}"
  export CARGO_HOME="${srcdir}/cargo"
  patch -Np1 -i "${srcdir}/0001-style-text-overlays-as-light-acrylic.patch"
  cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
  cd "niri-${pkgver}"
  export CARGO_HOME="${srcdir}/cargo"
  export NIRI_BUILD_COMMIT='8ed0da4'
  export NIRI_BUILD_VERSION_STRING="${pkgver}-${pkgrel}-acrylic (${NIRI_BUILD_COMMIT})"
  cargo build --frozen --release

  target/release/niri completions bash > niri.bash
  target/release/niri completions fish > niri.fish
  target/release/niri completions zsh > _niri
}

package() {
  cd "niri-${pkgver}"

  install -Dm755 target/release/niri "${pkgdir}/usr/bin/niri"
  install -Dm755 resources/niri-session "${pkgdir}/usr/bin/niri-session"

  install -Dm644 resources/niri.service \
    "${pkgdir}/usr/lib/systemd/user/niri.service"
  install -Dm644 resources/niri-shutdown.target \
    "${pkgdir}/usr/lib/systemd/user/niri-shutdown.target"

  install -Dm644 resources/niri.desktop \
    "${pkgdir}/usr/share/wayland-sessions/niri.desktop"
  install -Dm644 resources/niri-portals.conf \
    "${pkgdir}/usr/share/xdg-desktop-portal/niri-portals.conf"

  install -Dm644 niri.bash \
    "${pkgdir}/usr/share/bash-completion/completions/niri"
  install -Dm644 niri.fish \
    "${pkgdir}/usr/share/fish/vendor_completions.d/niri.fish"
  install -Dm644 _niri \
    "${pkgdir}/usr/share/zsh/site-functions/_niri"

  install -Dm644 README.md "${pkgdir}/usr/share/doc/niri/README.md"
  install -Dm644 resources/default-config.kdl \
    "${pkgdir}/usr/share/doc/niri/default-config.kdl"
}
