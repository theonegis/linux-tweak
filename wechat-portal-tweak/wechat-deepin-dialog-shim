    @dbus.service.method(DIALOG_IFACE, in_signature="s")
    def setCurrentInputName(self, name):
        log(f"{self.path} setCurrentInputName {name}")
        self.current_input_name = str(name)

    def _open_portal(self):
        log(f"{self.path} opening portal title={self.title} directory={self.directory} file_mode={self.file_mode} accept_mode={self.accept_mode} current_input_name={self.current_input_name}")
        portal = self.bus.get_object("org.freedesktop.portal.Desktop", "/org/freedesktop/portal/desktop")
        chooser = dbus.Interface(portal, "org.freedesktop.portal.FileChooser")
        options = {
            "modal": dbus.Boolean(True),
            "multiple": dbus.Boolean(self.file_mode == 3),
            "directory": dbus.Boolean(self.file_mode == 2),
        }
        current_folder = self.directory if os.path.isdir(self.directory) else str(Path.home())
        options["current_folder"] = dbus.ByteArray(os.fsencode(current_folder))

        if self.accept_mode == 1:
            if self.current_input_name:
                options["current_name"] = dbus.String(self.current_input_name)
            request_path = chooser.SaveFile("", self.title or "Save", options)
        else:
            request_path = chooser.OpenFile("", self.title or "Open", options)

        self.portal_request = str(request_path)
        self.bus.add_signal_receiver(
            self._portal_response,
            signal_name="Response",
            dbus_interface="org.freedesktop.portal.Request",
            path=self.portal_request,
        )
        log(f"{self.path} portal request {self.portal_request}")

    def _portal_response(self, response, results):
        log(f"{self.path} portal response response={response} results={dict(results)!r}")
        if int(response) == 0:
            uris = [str(uri) for uri in results.get("uris", [])]
            self.selected_urls_value = dbus.Array(uris, signature="s")
            self.selected_files_value = dbus.Array([file_uri_to_path(uri) for uri in uris], signature="s")
            self.accepted()
            self.finished(dbus.Int32(1))
        else:
            self.rejected()
            self.finished(dbus.Int32(0))

    @dbus.service.method(DIALOG_IFACE)
    def show(self):
        log(f"{self.path} show")
        self._open_portal()

    @dbus.service.method(DIALOG_IFACE)
    def open(self):
        log(f"{self.path} open")
        self._open_portal()

